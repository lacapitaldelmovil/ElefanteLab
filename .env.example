# ─── Elefante Lab – Variables de entorno ────────────────────────────────────
# Copia este archivo a .env (nunca lo subas a git) y configura los valores.
# En Railway: Service -> Variables.

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000

# ── Formulario de contacto (correo saliente) ──────────────────────────────────
# Si SMTP_PASS no esta configurado, el servidor guardara el contacto en
# contacts.log y respondera error para que no parezca enviado.

SMTP_HOST=smtp.ionos.es
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=admin@lacapital.es
SMTP_PASS=pon-aqui-la-contrasena-smtp-en-railway
SMTP_FROM_EMAIL=admin@lacapital.es
SMTP_FROM_NAME=Elefante Lab

# Dirección que RECIBE los mensajes del formulario
# (por defecto es SMTP_USER si no se define)
MAIL_TO=admin@lacapital.es
