# ─── Elefante Lab – Variables de entorno ────────────────────────────────────
# Copia este archivo a .env (nunca lo subas a git) y configura los valores.
# En Replit: usa la pestaña "Secrets" (🔒) para añadir estas variables.

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000

# ── Formulario de contacto (correo saliente) ──────────────────────────────────
# Si no configuras SMTP, los mensajes del formulario se guardan en contacts.log
# (en el servidor) y el usuario ve "¡Mensaje recibido!" igualmente.

# Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
#   → Genera una "Contraseña de aplicación" en tu cuenta Google
#   → https://myaccount.google.com/apppasswords
#
# Otro proveedor: usa los datos SMTP de tu panel de hosting.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion

# Dirección que RECIBE los mensajes del formulario
# (por defecto es SMTP_USER si no se define)
MAIL_TO=admin@lacapital.es
